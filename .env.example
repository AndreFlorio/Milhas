# ============================================================
# VARIÁVEIS DE AMBIENTE — PastMilhas
# ============================================================

# --- LOCAL (desenvolvimento) ---
# Copie este arquivo para .env e preencha:
#   cp .env.example .env

# --- VERCEL (produção) ---
# O .env NÃO vai pro GitHub. Configure no painel da Vercel:
#   1. Acesse vercel.com → seu projeto → Settings → Environment Variables
#   2. Adicione: SERPAPI_KEY = sua_chave_serpapi
#   3. Marque: Production, Preview, Development
#   4. Clique Save e faça Redeploy (Deployments → ⋯ → Redeploy)

# SerpAPI — Google Flights (OBRIGATÓRIO para dados reais)
# Obtenha em: https://serpapi.com/manage-api-key
SERPAPI_KEY=

# Amadeus (opcional, fallback)
VITE_AMADEUS_CLIENT_ID=
VITE_AMADEUS_CLIENT_SECRET=
