{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "functions": {
    "api/flights/search.js": {
      "maxDuration": 30
    },
    "api/reservations/lookup.js": {
      "maxDuration": 60,
      "memory": 1024
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ]
}
